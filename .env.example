# Copy this file to .env and fill in your values.
# .env is git-ignored and never committed.

# ── Required: Telegram alerts ────────────────────────────────
# Get a bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Your personal Telegram chat ID (send /start to @userinfobot to find it)
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Optional: Twelve Data API (alternative data source) ──────
# Free plan: 800 credits/day. Leave blank to use yfinance (default).
TWELVEDATA_API_KEY=your_twelvedata_key_here

# ── Optional: operational settings (uncomment to override) ───
# DATA_SOURCE=yfinance          # yfinance | twelvedata
# TIMEFRAME=15m                 # 1m 5m 15m 30m 1h
# SCAN_INTERVAL_SECONDS=60
# LOOKBACK_DAYS=3
# SWING_LOOKBACK_DAYS=7
# SMT_LOOKBACK_CANDLES=10
# SMT_TOLERANCE_PCT=0.0015
# SWING_STRENGTH=2
